{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bid Package",
  "description": "Schema for multi-document construction/trade bid packages. Validates the data.json that drives cover letters, proposals, leave-behinds, phone scripts, and follow-up emails.",
  "type": "object",
  "required": ["meta", "bidder", "project", "bid", "schedule_of_values", "exclusions", "clarifications", "allowances"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["bid_date", "bid_validity_days", "version"],
      "properties": {
        "bid_date": {
          "type": "string",
          "description": "Human-readable bid date, e.g. 'April 15, 2026'"
        },
        "bid_validity_days": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of calendar days the bid is firm"
        },
        "version": {
          "type": "string",
          "description": "Document version identifier, e.g. 'v1.0'"
        }
      }
    },
    "bidder": {
      "type": "object",
      "required": ["name", "owner", "license", "address_line", "phone", "email"],
      "properties": {
        "name": {"type": "string", "description": "Company legal name"},
        "owner": {"type": "string", "description": "Owner / principal name"},
        "tagline": {"type": "string", "description": "Short tagline for letterhead, e.g. 'Commercial . Residential . Healthcare'"},
        "license": {"type": "string", "description": "License number and class"},
        "monetary_limit": {"type": "string", "description": "License monetary limit"},
        "address_line": {"type": "string", "description": "Street address, city, state, zip"},
        "phone": {"type": "string", "description": "Phone number"},
        "email": {"type": "string", "format": "email", "description": "Contact email"},
        "logo": {"type": "string", "description": "Path to logo image file (relative to pack root)"}
      }
    },
    "project": {
      "type": "object",
      "required": ["name", "gc", "gc_attn_primary", "site_address", "building_size_sf", "building_type"],
      "properties": {
        "name": {"type": "string", "description": "Project name"},
        "owner_legal": {"type": "string", "description": "Project owner legal entity"},
        "owner_dba": {"type": "string", "description": "Project owner DBA / trade name"},
        "gc": {"type": "string", "description": "General contractor name"},
        "gc_attn_primary": {"type": "string", "description": "Primary GC contact with title"},
        "gc_attn_secondary": {"type": "string", "description": "Secondary GC contact with title"},
        "gc_location": {"type": "string", "description": "GC office location for address block"},
        "site_address": {"type": "string", "description": "Project site address"},
        "site_description": {"type": "string", "description": "Legal/parcel description of the site"},
        "building_size_sf": {"type": "integer", "minimum": 1, "description": "Building size in square feet"},
        "building_type": {"type": "string", "description": "Building type description"},
        "layout": {"type": "string", "description": "Building program / layout summary"}
      }
    },
    "bid": {
      "type": "object",
      "required": ["headline", "headline_label"],
      "properties": {
        "tiers": {
          "type": "array",
          "description": "Bid tier options (aggressive, standard, comfortable)",
          "items": {
            "type": "object",
            "required": ["name", "amount"],
            "properties": {
              "name": {"type": "string"},
              "amount": {"type": "number"},
              "use_when": {"type": "string"}
            }
          }
        },
        "headline": {"type": "number", "description": "Headline bid amount (numeric)"},
        "headline_label": {"type": "string", "description": "Formatted headline bid, e.g. '$425,000'"},
        "floor": {"type": "number", "description": "Absolute minimum bid floor"}
      }
    },
    "local_comps": {
      "type": "object",
      "description": "Local comparable projects for market context (free-form keys)",
      "additionalProperties": true
    },
    "schedule_of_values": {
      "type": "array",
      "minItems": 1,
      "description": "Line-item cost breakdown grouped by section",
      "items": {
        "type": "object",
        "required": ["section", "lines"],
        "properties": {
          "section": {"type": "string", "description": "Section name"},
          "lines": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["desc", "amount"],
              "properties": {
                "desc": {"type": "string", "description": "Line item description"},
                "amount": {"type": "number", "minimum": 0, "description": "Dollar amount"}
              }
            }
          }
        }
      }
    },
    "exclusions": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Items explicitly excluded from the bid"
    },
    "clarifications": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Bid clarifications and assumptions"
    },
    "allowances": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["num", "desc", "amount"],
        "properties": {
          "num": {"type": "integer", "description": "Allowance number"},
          "desc": {"type": "string", "description": "Allowance description"},
          "amount": {"type": "number", "minimum": 0, "description": "Allowance dollar amount"}
        }
      }
    },
    "growth_pitch": {
      "type": "string",
      "description": "Narrative about the client's growth trajectory and long-term partnership opportunity"
    },
    "differentiators": {
      "type": "object",
      "properties": {
        "headline": {"type": "string"},
        "points": {"type": "array", "items": {"type": "string"}}
      },
      "description": "Key differentiators for why the bidder should win"
    },
    "phone_scripts": {
      "type": "array",
      "description": "Pre-bid verification phone call scripts",
      "items": {
        "type": "object",
        "required": ["call_number", "contact_name", "organization", "phone", "questions"],
        "properties": {
          "call_number": {"type": "integer"},
          "contact_name": {"type": "string"},
          "organization": {"type": "string"},
          "phone": {"type": "string"},
          "opening": {"type": "string"},
          "questions": {"type": "array", "items": {"type": "string"}},
          "write_down": {"type": "string"}
        }
      }
    },
    "schedule_milestones": {
      "type": "array",
      "description": "Project schedule milestones",
      "items": {
        "type": "object",
        "required": ["milestone", "target"],
        "properties": {
          "milestone": {"type": "string"},
          "target": {"type": "string"}
        }
      }
    },
    "payment_terms": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Payment term bullet points"
    },
    "about": {
      "type": "string",
      "description": "Company background paragraph"
    },
    "licensure": {
      "type": "object",
      "properties": {
        "number": {"type": "string"},
        "limit": {"type": "string"},
        "valid_through": {"type": "string"},
        "type": {"type": "string"}
      }
    },
    "insurance": {
      "type": "string",
      "description": "Insurance and bonding summary"
    }
  }
}
