{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Invoice",
  "description": "Schema for branded invoice documents with line items, tax, and payment terms.",
  "type": "object",
  "required": ["from", "to", "invoice_number", "date", "due_date", "line_items", "subtotal", "total", "payment_terms"],
  "properties": {
    "from": {
      "type": "object",
      "required": ["name", "address", "email"],
      "properties": {
        "name": {"type": "string", "description": "Sender company or individual name"},
        "address": {"type": "string", "description": "Sender address (multi-line allowed)"},
        "email": {"type": "string", "format": "email", "description": "Sender email"},
        "phone": {"type": "string", "description": "Sender phone number"},
        "logo": {"type": "string", "description": "Path to sender logo image (relative to pack root)"},
        "website": {"type": "string", "description": "Sender website URL"},
        "tax_id": {"type": "string", "description": "Tax ID or EIN"}
      }
    },
    "to": {
      "type": "object",
      "required": ["name", "address"],
      "properties": {
        "name": {"type": "string", "description": "Recipient company or individual name"},
        "address": {"type": "string", "description": "Recipient address"},
        "email": {"type": "string", "format": "email", "description": "Recipient email"}
      }
    },
    "invoice_number": {
      "type": "string",
      "description": "Invoice number, e.g. 'INV-2026-0042'"
    },
    "date": {
      "type": "string",
      "description": "Invoice date in human-readable format"
    },
    "due_date": {
      "type": "string",
      "description": "Payment due date"
    },
    "line_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description", "qty", "rate", "amount"],
        "properties": {
          "description": {"type": "string", "description": "Line item description"},
          "qty": {"type": "number", "minimum": 0, "description": "Quantity"},
          "rate": {"type": "number", "minimum": 0, "description": "Unit rate/price"},
          "amount": {"type": "number", "minimum": 0, "description": "Line total (qty x rate)"}
        }
      },
      "description": "Invoice line items"
    },
    "subtotal": {
      "type": "number",
      "minimum": 0,
      "description": "Subtotal before tax"
    },
    "tax_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Tax rate as decimal, e.g. 0.0925 for 9.25%"
    },
    "tax": {
      "type": "number",
      "minimum": 0,
      "description": "Tax amount"
    },
    "total": {
      "type": "number",
      "minimum": 0,
      "description": "Grand total including tax"
    },
    "payment_terms": {
      "type": "string",
      "description": "Payment terms description, e.g. 'Net 30'"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes or instructions"
    },
    "currency": {
      "type": "string",
      "description": "Currency symbol, default '$'"
    }
  }
}
