{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Report Package",
  "description": "Schema for multi-page research or analysis reports with table of contents, executive summary, content sections, and appendices.",
  "type": "object",
  "required": ["title", "author", "date", "exec_summary", "sections"],
  "properties": {
    "title": {
      "type": "string",
      "description": "Report title"
    },
    "subtitle": {
      "type": "string",
      "description": "Report subtitle"
    },
    "author": {
      "type": "string",
      "description": "Author name or organization"
    },
    "date": {
      "type": "string",
      "description": "Report date in human-readable format"
    },
    "version": {
      "type": "string",
      "description": "Document version, e.g. 'v1.0'"
    },
    "classification": {
      "type": "string",
      "description": "Document classification, e.g. 'Confidential'"
    },
    "logo": {
      "type": "string",
      "description": "Path to organization logo (relative to pack root)"
    },
    "exec_summary": {
      "type": "string",
      "description": "Executive summary text (1-3 paragraphs)"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "content"],
        "properties": {
          "title": {
            "type": "string",
            "description": "Section title"
          },
          "content": {
            "type": "string",
            "description": "Section body content (supports basic HTML for lists, emphasis)"
          },
          "subsections": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["title", "content"],
              "properties": {
                "title": {"type": "string", "description": "Subsection title"},
                "content": {"type": "string", "description": "Subsection content"}
              }
            },
            "description": "Optional subsections within this section"
          }
        }
      },
      "description": "Report body sections"
    },
    "appendices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "content"],
        "properties": {
          "title": {"type": "string", "description": "Appendix title"},
          "content": {"type": "string", "description": "Appendix content"}
        }
      },
      "description": "Optional appendices"
    },
    "references": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Optional list of references or citations"
    }
  }
}
